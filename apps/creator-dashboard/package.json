{
  "name": "wake-web-dashboard",
  "version": "1.0.0",
  "description": "Wake Creator Dashboard - Web App",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' vite build",
    "build:verbose": "NODE_OPTIONS='--max-old-space-size=8192' vite build --debug",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "vitest run --config vitest.config.rules.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.17.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "dompurify": "^3.3.3",
    "firebase": "^12.3.0",
    "html5-qrcode": "^2.3.8",
    "lodash": "^4.17.21",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "react": "^18.2.0",
    "react-country-state-city": "^1.1.12",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-window": "^2.2.3",
    "recharts": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^28.1.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
