rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if user is the owner of a resource
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // F-RULES-02: role authority is the custom claim, period. The Firestore
    // fallback is removed so a user who self-writes role on their own users/
    // {uid} doc (which F-RULES-01 lockdown also prevents) can no longer flip
    // isAdmin() / isCreator() at evaluation time. phase1-claim-backfill.js
    // stamps the claim for existing creator/admin users; missing claim or
    // empty string defaults to 'user'.
    function getUserRole() {
      return isSignedIn() ? request.auth.token.get('role', 'user') : 'user';
    }
    
    // Check if user is admin
    function isAdmin() {
      return getUserRole() == 'admin';
    }
    
    // Check if user is creator
    function isCreator() {
      return getUserRole() == 'creator' || isAdmin();
    }
    
    // ============================================
    // USER DATA
    // ============================================

    // Users collection - owner or admin can read/update
    // Creator access to client data is API-mediated (Admin SDK bypasses rules)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // F-RULES-01 / F-RULES-02 lockdown.
      // Owner updates are restricted to a non-privileged allowlist of
      // profile-shape fields. Privileged fields — role, courses,
      // subscriptions, email, email_verified, trial_used, purchased_courses,
      // username, created_at, cards — are Admin-SDK-only (the API mutates
      // them server-side, bypassing rules). Admin retains full update access.
      // Length caps on user-controlled string fields prevent a single self-
      // update from bloating the user doc toward Firestore's 1MiB limit
      // (the doc is read on every login).
      allow update: if (isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'profilePictureUrl',
          'country', 'city', 'gender',
          'height', 'weight', 'bodyweight', 'goalWeight', 'weightUnit',
          'birthDate', 'phoneNumber',
          'bio',
          'onboardingData', 'creatorOnboardingData',
          'webOnboardingCompleted', 'profileCompleted',
          'onboardingCompleted', 'bibliotecaGuideCompleted',
          'pinnedTrainingCourseId', 'pinnedNutritionAssignmentId',
          'beholdFeedId',
          'creatorDiscipline', 'creatorDeliveryType', 'creatorClientRange',
          'creatorSpecializations', 'creatorExperience', 'creatorCertifications',
          'creatorNavPreferences', 'socialLinks', 'websiteUrl',
          'howTheyFoundUs',
          'lastSessionDate', 'updated_at'
        ]) &&
        request.resource.data.get('displayName', '').size() < 100 &&
        request.resource.data.get('bio', '').size() < 1000 &&
        request.resource.data.get('websiteUrl', '').size() < 500 &&
        request.resource.data.get('howTheyFoundUs', '').size() < 1000 &&
        request.resource.data.get('city', '').size() < 100 &&
        request.resource.data.get('country', '').size() < 100 &&
        request.resource.data.get('phoneNumber', '').size() < 50
      ) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
      
      // Exercise history subcollections
      match /exerciseHistory/{exerciseKey} {
        allow read, write: if isOwner(userId);
      }
      
      // Session history subcollections
      match /sessionHistory/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      // Abandoned session records — written server-side only
      match /abandonedSessions/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      // Readiness check-in (one doc per day)
      match /readiness/{date} {
        allow read, write: if isOwner(userId);
      }

      // Body progress log (one doc per day: weight + photos)
      match /bodyLog/{dateStr} {
        allow read, write: if isOwner(userId);
      }

      // Nutrition diary entries
      match /diary/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // User meals
      match /meals/{mealId} {
        allow read, write: if isOwner(userId);
      }

      // MercadoPago subscription records — owner read, server write only
      match /subscriptions/{subId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      // Per-exercise last performance (quick lookup)
      match /exerciseLastPerformance/{key} {
        allow read, write: if isOwner(userId);
      }

      // Saved foods (user's personal food library)
      match /saved_foods/{foodId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ============================================
    // ONE-ON-ONE CLIENTS
    // ============================================
    
    // One-on-one clients collection
    match /one_on_one_clients/{clientDocId} {
      // Creator can read/write their own clients
      // Client can read their own record
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || 
        resource.data.clientUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && isCreator() && request.resource.data.creatorId == request.auth.uid;
      // F-RULES-31 (Round 2): creatorId / clientUserId / createdAt are
      // immutable on update — preventing the owner-creator from flipping
      // clientUserId to attach a victim as their client.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.creatorId == request.auth.uid &&
         request.resource.data.creatorId == resource.data.creatorId &&
         request.resource.data.get('clientUserId', '') == resource.data.get('clientUserId', '') &&
         request.resource.data.get('createdAt', resource.data.get('createdAt', null)) == resource.data.get('createdAt', null))
      );
      allow delete: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isAdmin()
      );
    }

    // ============================================
    // VIDEO EXCHANGES
    // ============================================

    match /video_exchanges/{exchangeId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow write: if false; // All writes through API

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/video_exchanges/$(exchangeId)).data.creatorId == request.auth.uid ||
          get(/databases/$(database)/documents/video_exchanges/$(exchangeId)).data.clientId == request.auth.uid ||
          isAdmin()
        );
        allow write: if false; // All writes through API
      }
    }

    // ============================================
    // COURSE CONTENT
    // ============================================
    
    // Courses
    // - Published courses (status 'published') are readable by all authenticated users
    // - Draft/unpublished courses are only readable by their creator or admins
    // - Courses with no status field are treated as published for backward compatibility
    // - F-2026-05-01: legacy Spanish 'publicado' branch removed. Production
    //   shape-analysis 2026-05-02 confirmed zero docs use it; the parallel
    //   blacklist in isFreeGrantAllowed (helper) was a monetization bypass
    //   primitive and has been replaced by a strict allowlist.
    match /courses/{courseId} {
      allow read: if isSignedIn() && (
        resource.data.get('status', '') == 'published' ||
        resource.data.get('status', '') == '' ||
        isAdmin() ||
        (isCreator() && resource.data.get('creator_id', '') == request.auth.uid)
      );

      // F-RULES-19 (Round 2): bind creator_id at create-time so a creator
      // cannot orphan a course attributed to another creator.
      allow create: if isCreator()
        && request.resource.data.get('creator_id', '') == request.auth.uid;

      // F-RULES-19 (Round 2): creator_id is immutable on update — diff-guard
      // forbids reassignment.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isCreator()
         && resource.data.get('creator_id', '') == request.auth.uid
         && request.resource.data.get('creator_id', '') == resource.data.get('creator_id', ''))
      );
      allow delete: if isAdmin();
      
      // Modules subcollection - nested under courses
      // Security (audit H-01): writes scoped to the creator who owns the
      // parent course doc. Previously `isCreator() || isAdmin()` allowed any
      // creator to mutate or delete any other creator's program content.
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isCreator() &&
          get(/databases/$(database)/documents/courses/$(courseId)).data.get('creator_id', '') == request.auth.uid);

        // Sessions subcollection - nested under modules
        match /sessions/{sessionId} {
          allow read: if isSignedIn();
          allow write: if isAdmin() || (isCreator() &&
            get(/databases/$(database)/documents/courses/$(courseId)).data.get('creator_id', '') == request.auth.uid);

          // Exercises subcollection - nested under sessions
          match /exercises/{exerciseId} {
            allow read: if isSignedIn();
            allow write: if isAdmin() || (isCreator() &&
              get(/databases/$(database)/documents/courses/$(courseId)).data.get('creator_id', '') == request.auth.uid);

            // Sets subcollection - nested under exercises
            match /sets/{setId} {
              allow read: if isSignedIn();
              allow write: if isAdmin() || (isCreator() &&
                get(/databases/$(database)/documents/courses/$(courseId)).data.get('creator_id', '') == request.auth.uid);
            }
          }
        }
      }
    }
    
    // ============================================
    // USER PROGRESS & DATA (LEGACY — 0 docs in prod)
    // ============================================
    // F-RULES-16 / F-RULES-17 (Round 2): the previous rules accepted
    // `request.resource.data.userId == auth.uid` for create on doc IDs that
    // could begin with another user's UID prefix — letting an attacker
    // poison `user_progress/<victimUid>_courseX` with their own data, which
    // the victim's docId-prefix read would then surface. Production has 0
    // docs in either collection (verified shape-analysis 2026-05-01).
    // Locked to docId-prefix only; the userId-field branch is gone.
    match /user_progress/{docId} {
      allow read: if isSignedIn() && (
        docId == request.auth.uid ||
        docId.matches('^' + request.auth.uid + '_.*')
      );
      allow write: if isSignedIn() && (
        docId == request.auth.uid ||
        docId.matches('^' + request.auth.uid + '_.*')
      );
    }
    match /completed_sessions/{docId} {
      allow read, create, update, delete: if isSignedIn() &&
        docId.matches('^' + request.auth.uid + '_.*');
    }
    
    // ============================================
    // APP RESOURCES
    // ============================================
    
    // Disciplines - all authenticated users can read
    match /disciplines/{disciplineId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // App resources - publicly readable (needed for asset bundle initialization before auth)
    // These are public app assets (videos/images), not sensitive user data
    match /app_resources/{resourceId} {
      allow read: if true; // Public read access for app assets
      allow write: if isAdmin();
    }
    
    // ============================================
    // PURCHASES
    // ============================================
    
    // F-RULES-08 (Round 2): purchases are server-only — collection has 0
    // docs in prod (verified shape-analysis 2026-05-01), and the canonical
    // payment record lives in `processed_payments`. Locking writes to admin
    // closes the forge-purchase-row paywall-bypass surface preemptively.
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.user_id == request.auth.uid
      );
      allow write: if isAdmin();
    }
    
    // ============================================
    // ACCOUNT DELETION FEEDBACK
    // ============================================
    
    // Account deletion feedback - users can create their own feedback, admins can read all
    // F-RULES-40 (Round 2): cap doc shape so a single create can't bloat
    // toward Firestore's 1MiB limit (matches subscription_cancellation_feedback pattern).
    match /account_deletion_feedback/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId', 'reason', 'feedback', 'submittedAt', 'source',
          'subscriptionStatus', 'hadActiveSubscription'
        ]);
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // CREATOR MEDIA (personal folder for images/videos)
    // ============================================
    match /creator_media/{creatorId} {
      allow read, write: if isSignedIn() && request.auth.uid == creatorId;
      match /files/{fileId} {
        allow read, write: if isSignedIn() && request.auth.uid == creatorId;
      }
    }

    // ============================================
    // CALL BOOKING: Creator availability (time slots)
    // ============================================
    // Security (audit H-03 / Tier 5.1): owner-only read. Booking flows on PWA
    // and creator dashboard read availability via the API, so no client needs
    // direct Firestore read access. Closes BI leakage of competitor schedules.
    match /creator_availability/{creatorId} {
      allow read: if isOwner(creatorId) || isAdmin();
      // F-RULES-32 (Round 2): creator may only write their own availability;
      // doc shape constrained to a known field allowlist so a creator can't
      // pollute the doc with unrelated keys.
      allow create, update: if isSignedIn() && request.auth.uid == creatorId
        && request.resource.data.keys().hasOnly([
          'slots', 'timezone', 'updatedAt', 'createdAt'
        ]);
      allow delete: if isSignedIn() && request.auth.uid == creatorId;
    }

    // Call bookings (sales call / one-on-one slot)
    match /call_bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.clientUserId == request.auth.uid;
      // L-08: clients may only mutate their own status / notes fields. Creator
      // and admin retain full update. Server (Admin SDK) bypasses rules and
      // owns all other transitions. Without this, a client could overwrite
      // creator-owned fields (callLink, slotStartUtc, creatorId).
      // F-RULES-12 (Round 2): client may only set status to `cancelled` —
      // marking a booking `confirmed` or `completed` is creator/admin-only.
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isAdmin() ||
        (resource.data.clientUserId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'status', 'cancelled_by_client', 'cancellation_reason',
           'notes', 'updatedAt'
         ]) &&
         (!('status' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.status == 'cancelled'))
      );
      allow delete: if false;
    }

    // ============================================
    // NUTRITION (creator library, assignments, user diary)
    // ============================================
    match /creator_nutrition_library/{creatorId}/meals/{mealId} {
      allow read, write: if isSignedIn() && request.auth.uid == creatorId;
    }
    match /creator_nutrition_library/{creatorId}/plans/{planId} {
      allow read, write: if isSignedIn() && request.auth.uid == creatorId;
    }
    match /creator_nutrition_library/{creatorId}/programs/{programId} {
      allow read, write: if isSignedIn() && request.auth.uid == creatorId;
    }

    // F-DATA-01 / F-DATA-06: canonical creator field is `creator_id` (snake).
    // Legacy `assignedBy` is accepted alongside `creator_id` during the
    // migration window. scripts/archive/security-2026-05/naming-drift-normalize.js
    // normalizes data; once the legacy field is gone from prod, the
    // assignedBy clauses can be removed in Round 2.
    // F-RULES-09 (Round 2): writes locked to admin (Admin SDK API endpoints
    // mediate creates/updates/deletes and validate the creator↔client
    // relationship before writing — no client SDK call path exists, verified
    // via grep of apps/pwa/src + apps/creator-dashboard/src).
    match /nutrition_assignments/{assignmentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.get('creator_id', '') == request.auth.uid ||
        resource.data.get('assignedBy', '') == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    // F-RULES-10 (Round 2): writes locked to admin (same shape as
    // nutrition_assignments — API mediates and validates relationship).
    match /client_nutrition_plan_content/{assignmentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.get('creator_id', '') == request.auth.uid ||
        resource.data.get('assignedBy', '') == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    // ============================================
    // EVENTS
    // ============================================

    match /events/{eventId} {
      allow read: if true;
      allow create: if isCreator() && request.resource.data.creator_id == request.auth.uid;
      // F-RULES-21 (Round 2): creator may update event metadata but NOT
      // the server-managed registration_count counter (sendEventConfirmationEmail
      // owns it). creator_id and created_at are also immutable. Admin retains
      // full update.
      // F-2026-05-02 (Round 3): cap the doc shape to a known field allowlist
      // so a creator using the JS SDK directly can't bypass the API's
      // assertHttpsUrl(image_url) check by writing arbitrary fields. The
      // allowlist mirrors PATCH /creator/events/:eventId's allowedFields
      // (events.ts:424) plus the immutable bookkeeping fields the rule
      // already enforces individually. og_image_url is server-managed by the
      // generateOgImage helper but stays writable — Admin SDK bypasses rules
      // and the field never carries a CSS-context render path today.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.creator_id == request.auth.uid &&
         request.resource.data.creator_id == resource.data.creator_id &&
         request.resource.data.get('created_at', resource.data.get('created_at', null)) ==
           resource.data.get('created_at', null) &&
         request.resource.data.get('registration_count', 0) ==
           resource.data.get('registration_count', 0) &&
         request.resource.data.keys().hasOnly([
           'title', 'description', 'date', 'location',
           'max_registrations', 'maxRegistrations',
           'fields', 'capacity', 'image_url', 'og_image_url',
           'settings', 'access', 'status',
           'creator_id', 'creatorId', 'created_at', 'createdAt',
           'updated_at', 'updatedAt',
           'registration_count'
         ]))
      );
      allow delete: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid || isAdmin()
      );
    }

    match /event_signups/{eventId}/registrations/{regId} {
      // F-RULES-06 / F-RULES-41 / F-FUNCS-17: bind email + userId to caller.
      // - Authed registrant: userId must equal auth.uid; if an email field
      //   is provided, it must match the auth-token email (prevents using
      //   a victim's address as the recipient of the confirmation email).
      // - Unauthed registrant on a non-`wake_users_only` event: the doc
      //   must NOT carry a userId field (so the unauth path can't claim
      //   identity). The Cloud Function rate-limits the unauth flow.
      // F-RULES-06 (Round 2): cap doc shape to a known field allowlist so a
      // registrant can't bloat the doc toward Firestore's 1MiB limit (this
      // collection accepts unauth writes for public events, so the surface
      // is broader than other create paths).
      allow create: if (
        (isSignedIn()
          && request.resource.data.get('userId', '') == request.auth.uid
          && (!('email' in request.resource.data.keys())
              || request.resource.data.email == request.auth.token.get('email', '')))
        ||
        (!isSignedIn()
          && get(/databases/$(database)/documents/events/$(eventId)).data.get('wake_users_only', false) == false
          && !('userId' in request.resource.data.keys()))
      ) && request.resource.data.keys().hasOnly([
        'userId', 'email', 'nombre', 'displayName', 'phoneNumber',
        'responses', 'fieldValues', 'created_at', 'createdAt',
        'checked_in', 'checkedIn', 'checked_in_at', 'checkedInAt',
        'check_in_token', 'source'
      ]);
      // Creator and admin can read all registrations; registrant can read their own (by doc id matching uid)
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(eventId)).data.creator_id == request.auth.uid
        || isAdmin()
        || regId == request.auth.uid
        || resource.data.get('userId', '') == request.auth.uid
      );
      allow update: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(eventId)).data.creator_id == request.auth.uid
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /event_signups/{eventId}/waitlist/{waitId} {
      // Security (audit H-02): require auth + bind userId to caller. Previously
      // `allow create: if true` allowed unauthenticated public writes with no
      // schema constraints — anyone could spam arbitrary docs into any event's
      // waitlist subcollection.
      // Field allowlist mirrors registrations to prevent doc-shape bloat.
      allow create: if isSignedIn()
        && (
          request.resource.data.get('userId', '') == request.auth.uid
          || waitId == request.auth.uid
        )
        && request.resource.data.keys().hasOnly([
          'userId', 'email', 'nombre', 'displayName', 'phoneNumber',
          'responses', 'fieldValues', 'created_at', 'createdAt',
          'source'
        ]);
      // Creator and admin can read all waitlist entries; waitlist user can read their own
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(eventId)).data.creator_id == request.auth.uid
        || isAdmin()
        || waitId == request.auth.uid
        || resource.data.get('userId', '') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ============================================
    // CREATOR FEEDBACK (suggestions / bug reports)
    // ============================================
    // F-RULES-39 (Round 2): cap doc shape (1MiB-bloat defense).
    match /creator_feedback/{feedbackId} {
      allow create: if isSignedIn() && isCreator()
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'creatorId', 'category', 'message', 'submittedAt',
          'source', 'attachmentPath', 'metadata'
        ]);
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // PLANS (one-on-one delivery)
    // ============================================
    match /plans/{planId} {
      // Creator owner and admin can read/write; enrolled client can read their assigned plan
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isAdmin() ||
        resource.data.get('clientUserId', '') == request.auth.uid
      );
      allow create: if isCreator() && request.resource.data.creatorId == request.auth.uid;
      // F-RULES-33 (Round 2): creatorId / clientUserId / createdAt are
      // immutable on update — preventing a creator from flipping the
      // assigned client to surface plan content under another user.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.creatorId == request.auth.uid &&
         request.resource.data.creatorId == resource.data.creatorId &&
         request.resource.data.get('clientUserId', '') == resource.data.get('clientUserId', '') &&
         request.resource.data.get('createdAt', resource.data.get('createdAt', null)) == resource.data.get('createdAt', null))
      );
      allow delete: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
      match /modules/{moduleId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/plans/$(planId)).data.creatorId == request.auth.uid
          || get(/databases/$(database)/documents/plans/$(planId)).data.get('clientUserId', '') == request.auth.uid
          || isAdmin()
        );
        allow write: if isSignedIn() && (
          get(/databases/$(database)/documents/plans/$(planId)).data.creatorId == request.auth.uid
          || isAdmin()
        );
        match /sessions/{sessionId} {
          allow read: if isSignedIn() && (
            get(/databases/$(database)/documents/plans/$(planId)).data.creatorId == request.auth.uid
            || get(/databases/$(database)/documents/plans/$(planId)).data.get('clientUserId', '') == request.auth.uid
            || isAdmin()
          );
          allow write: if isSignedIn() && (
            get(/databases/$(database)/documents/plans/$(planId)).data.creatorId == request.auth.uid
            || isAdmin()
          );
        }
      }
    }

    // ============================================
    // CREATOR LIBRARIES
    // ============================================
    match /creator_libraries/{creatorId} {
      allow read, write: if isOwner(creatorId) || isAdmin();
      match /sessions/{sessionId} {
        allow read, write: if isOwner(creatorId) || isAdmin();
      }
      match /modules/{moduleId} {
        allow read, write: if isOwner(creatorId) || isAdmin();
      }
    }

    // ============================================
    // EXERCISES LIBRARY (shared)
    // ============================================
    // Security (audit H-04): writes scoped to the document's creator_id field.
    // Previously `allow create, update: if isCreator()` let any creator
    // overwrite any other creator's exercise library.
    match /exercises_library/{exerciseId} {
      allow read: if isSignedIn();
      allow create: if isCreator()
        && request.resource.data.get('creator_id', '') == request.auth.uid;
      allow update: if isAdmin() || (isCreator()
        && resource.data.get('creator_id', '') == request.auth.uid
        && request.resource.data.get('creator_id', '') == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================
    // CLIENT PROGRAMS & SESSION CONTENT
    // ============================================

    // Client programs (doc id = userId_programId)
    // F-DATA-02 (Round 2): the previous rule predicates checked
    // `creatorId`/`clientId` fields that DON'T EXIST in any production doc
    // (real shape is `user_id` + `program_id`, snake). All client reads /
    // writes go through Admin-SDK API endpoints (verified: zero direct
    // Firestore SDK callers in apps/pwa or apps/creator-dashboard). Locking
    // this rule to deny-all closes the dead-rule risk surface; Admin SDK
    // bypasses rules and remains the sole writer. If a future client surface
    // needs direct read access, gate on `docId.matches('^' + auth.uid + '_.*')`
    // (safe — doc id is owner-prefixed) or `resource.data.user_id == auth.uid`.
    match /client_programs/{docId} {
      allow read, write: if isAdmin();
    }

    // One-on-one sessions assigned to a client
    match /client_sessions/{sessionId} {
      allow read: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid ||
        resource.data.client_id == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCreator()
        && request.resource.data.creator_id == request.auth.uid
        && request.resource.data.client_id is string;
      allow update: if isSignedIn() && (isAdmin() || (
        resource.data.creator_id == request.auth.uid
        && request.resource.data.creator_id == resource.data.creator_id
        && request.resource.data.client_id == resource.data.client_id
      ));
      allow delete: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid || isAdmin()
      );
    }

    // F-RULES-14 (Round 2): writes locked to admin (Admin SDK API mediates
    // and validates creator↔client relationship before writing).
    match /client_session_content/{docId} {
      allow read: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid ||
        resource.data.client_id == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    match /client_plan_content/{docId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCreator() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
    }

    // ============================================
    // PROGRESS (top-level, user_id field scoped)
    // ============================================
    match /progress/{docId} {
      allow read: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isAdmin()
      );
    }

    // ============================================
    // COMMUNITY
    // ============================================
    match /community/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isAdmin()
      );
    }

    // ============================================
    // SERVER-ONLY COLLECTIONS (never client-accessible)
    // ============================================

    // API keys — SHA-256 hashes, must never be readable from clients
    match /api_keys/{keyId} {
      allow read, write: if false;
    }

    // MercadoPago webhook idempotency records
    match /processed_payments/{paymentId} {
      allow read, write: if false;
    }

    // FatSecret API cache — server-managed
    match /fatsecret_cache/{cacheId} {
      allow read, write: if false;
    }

    // ============================================
    // SUBSCRIPTION CANCELLATION FEEDBACK
    // ============================================
    match /subscription_cancellation_feedback/{feedbackId} {
      // L-06: bound the keys a client can write so a single doc can't blow
      // up to the 1 MiB Firestore limit. Server (Admin SDK) writes bypass
      // rules and may set additional internal fields.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId', 'type', 'feedback', 'submittedAt',
          'subscriptionId', 'answers', 'source',
          'statusBefore', 'statusAfter',
          'courseId', 'courseTitle'
        ]);
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // PROGRAM LEAVE FEEDBACK
    // ============================================
    // Server-only reads. Creator sees aggregated counts via API only — never raw rows.
    match /program_leave_feedback/{feedbackId} {
      allow create: if false; // All writes via Cloud Function (Admin SDK bypasses)
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // WRITE ACCESS REQUESTS (developer portal)
    // ============================================
    // F-RULES-40 (Round 2): cap doc shape (1MiB-bloat defense).
    match /write_access_requests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId', 'email', 'displayName', 'reason',
          'requestedScopes', 'submittedAt', 'status'
        ]);
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // BUNDLES (multi-program SKUs)
    // ============================================
    match /bundles/{bundleId} {
      allow read: if resource.data.status == 'published'
                  || (isSignedIn() && request.auth.uid == resource.data.creatorId)
                  || isAdmin();
      allow create: if isSignedIn()
                    && isCreator()
                    && request.auth.uid == request.resource.data.creatorId
                    && request.resource.data.status == 'draft';
      // F-RULES-03 / F-RULES-20 (Round 2): on update, creatorId is immutable
      // (no transferring a bundle to another creator) and status transitions
      // are restricted to draft↔published (no inventing new status values).
      // Cross-creator courseIds in the bundle are still server-side enforced
      // by F-NEW-07 / F-SVC-01 in bundleAssignment.ts; the rule layer caps
      // the worst-case (publishing a bundle attributed to someone else).
      // Once published, a creator cannot revert to draft — prevents the
      // publish/unpublish cycle that would let pricing change after a buyer
      // sees the published listing. (No admin override exists at the rule
      // layer; admin SDK bypasses rules and can force a transition if needed.)
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.creatorId
        && request.resource.data.creatorId == resource.data.creatorId
        && (request.resource.data.status == 'draft' ||
            request.resource.data.status == 'published')
        && !(resource.data.status == 'published' && request.resource.data.status == 'draft');
      allow delete: if false;
    }

    // ============================================
    // ORPHANED LEGACY COLLECTIONS (zero code references, safe to delete from console)
    // - checkout_intents (4 docs)
    // - creator_client_access (7 docs) — replaced by one_on_one_clients
    // ============================================

    // ============================================
    // DEFAULT RULE — deny everything not explicitly covered
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
