rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if user is the owner of a resource
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Check user role — prefer custom claim (zero reads), fallback to Firestore lookup
    function getUserRole() {
      let tokenRole = isSignedIn() ? request.auth.token.get('role', null) : null;
      return tokenRole != null
        ? tokenRole
        : (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user')
            : 'user');
    }
    
    // Check if user is admin
    function isAdmin() {
      return getUserRole() == 'admin';
    }
    
    // Check if user is creator
    function isCreator() {
      return getUserRole() == 'creator' || isAdmin();
    }
    
    // ============================================
    // USER DATA
    // ============================================

    // Users collection - owner or admin can read/update
    // Creator access to client data is API-mediated (Admin SDK bypasses rules)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
      
      // Exercise history subcollections
      match /exerciseHistory/{exerciseKey} {
        allow read, write: if isOwner(userId);
      }
      
      // Session history subcollections
      match /sessionHistory/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      // Abandoned session records — written server-side only
      match /abandonedSessions/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      // Readiness check-in (one doc per day)
      match /readiness/{date} {
        allow read, write: if isOwner(userId);
      }

      // Body progress log (one doc per day: weight + photos)
      match /bodyLog/{dateStr} {
        allow read, write: if isOwner(userId);
      }

      // Nutrition diary entries
      match /diary/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // User meals
      match /meals/{mealId} {
        allow read, write: if isOwner(userId);
      }

      // MercadoPago subscription records — owner read, server write only
      match /subscriptions/{subId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      // Per-exercise last performance (quick lookup)
      match /exerciseLastPerformance/{key} {
        allow read, write: if isOwner(userId);
      }

      // Saved foods (user's personal food library)
      match /saved_foods/{foodId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ============================================
    // ONE-ON-ONE CLIENTS
    // ============================================
    
    // One-on-one clients collection
    match /one_on_one_clients/{clientDocId} {
      // Creator can read/write their own clients
      // Client can read their own record
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || 
        resource.data.clientUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && isCreator() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || 
        isAdmin()
      );
    }

    // ============================================
    // VIDEO EXCHANGES
    // ============================================

    match /video_exchanges/{exchangeId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow write: if false; // All writes through API

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/video_exchanges/$(exchangeId)).data.creatorId == request.auth.uid ||
          get(/databases/$(database)/documents/video_exchanges/$(exchangeId)).data.clientId == request.auth.uid ||
          isAdmin()
        );
        allow write: if false; // All writes through API
      }
    }

    // ============================================
    // COURSE CONTENT
    // ============================================
    
    // Courses
    // - Published courses (status 'publicado' or 'published') are readable by all authenticated users
    // - Draft/unpublished courses are only readable by their creator or admins
    // - Courses with no status field are treated as published for backward compatibility
    match /courses/{courseId} {
      allow read: if isSignedIn() && (
        resource.data.get('status', '') == 'publicado' ||
        resource.data.get('status', '') == 'published' ||
        resource.data.get('status', '') == '' ||
        isAdmin() ||
        (isCreator() && resource.data.get('creator_id', '') == request.auth.uid)
      );

      allow create: if isCreator();

      allow update: if isSignedIn() && (
        isAdmin() ||
        (isCreator() && resource.data.get('creator_id', '') == request.auth.uid)
      );
      allow delete: if isAdmin();
      
      // Modules subcollection - nested under courses
      // Security (audit H-01): writes scoped to the creator who owns the
      // parent course doc. Previously `isCreator() || isAdmin()` allowed any
      // creator to mutate or delete any other creator's program content.
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isCreator() &&
          get(/databases/$(database)/documents/courses/$(courseId)).data.get('creator_id', '') == request.auth.uid);

        // Sessions subcollection - nested under modules
        match /sessions/{sessionId} {
          allow read: if isSignedIn();
          allow write: if isAdmin() || (isCreator() &&
            get(/databases/$(database)/documents/courses/$(courseId)).data.get('creator_id', '') == request.auth.uid);

          // Exercises subcollection - nested under sessions
          match /exercises/{exerciseId} {
            allow read: if isSignedIn();
            allow write: if isAdmin() || (isCreator() &&
              get(/databases/$(database)/documents/courses/$(courseId)).data.get('creator_id', '') == request.auth.uid);

            // Sets subcollection - nested under exercises
            match /sets/{setId} {
              allow read: if isSignedIn();
              allow write: if isAdmin() || (isCreator() &&
                get(/databases/$(database)/documents/courses/$(courseId)).data.get('creator_id', '') == request.auth.uid);
            }
          }
        }
      }
    }
    
    // ============================================
    // USER PROGRESS & DATA (LEGACY - TO BE REMOVED)
    // ============================================
    
    // User progress - supports userId_courseId pattern
    // Allow if document ID starts with user's ID
    match /user_progress/{docId} {
      allow read: if isSignedIn() && (
        docId == request.auth.uid ||
        docId.matches('^' + request.auth.uid + '_.*')
      );
      allow write: if isSignedIn() && (
        docId == request.auth.uid ||
        docId.matches('^' + request.auth.uid + '_.*') ||
        request.resource.data.userId == request.auth.uid
      );
    }
    
    // Completed sessions - supports userId_courseId_timestamp pattern
    match /completed_sessions/{docId} {
      allow read: if isSignedIn() && (
        docId.matches('^' + request.auth.uid + '_.*') ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isSignedIn() && (
        docId.matches('^' + request.auth.uid + '_.*') ||
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if isSignedIn() && (
        docId.matches('^' + request.auth.uid + '_.*') ||
        resource.data.userId == request.auth.uid
      );
    }
    
    // ============================================
    // APP RESOURCES
    // ============================================
    
    // Disciplines - all authenticated users can read
    match /disciplines/{disciplineId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // App resources - publicly readable (needed for asset bundle initialization before auth)
    // These are public app assets (videos/images), not sensitive user data
    match /app_resources/{resourceId} {
      allow read: if true; // Public read access for app assets
      allow write: if isAdmin();
    }
    
    // ============================================
    // PURCHASES
    // ============================================
    
    // Purchases - users can create their own, admins can read all
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.user_id == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // ACCOUNT DELETION FEEDBACK
    // ============================================
    
    // Account deletion feedback - users can create their own feedback, admins can read all
    match /account_deletion_feedback/{feedbackId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // CREATOR MEDIA (personal folder for images/videos)
    // ============================================
    match /creator_media/{creatorId} {
      allow read, write: if isSignedIn() && request.auth.uid == creatorId;
      match /files/{fileId} {
        allow read, write: if isSignedIn() && request.auth.uid == creatorId;
      }
    }

    // ============================================
    // CALL BOOKING: Creator availability (time slots)
    // ============================================
    // Security (audit H-03 / Tier 5.1): owner-only read. Booking flows on PWA
    // and creator dashboard read availability via the API, so no client needs
    // direct Firestore read access. Closes BI leakage of competitor schedules.
    match /creator_availability/{creatorId} {
      allow read: if isOwner(creatorId) || isAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == creatorId;
      allow delete: if isSignedIn() && request.auth.uid == creatorId;
    }

    // Call bookings (sales call / one-on-one slot)
    match /call_bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.clientUserId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientUserId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if false;
    }

    // ============================================
    // NUTRITION (creator library, assignments, user diary)
    // ============================================
    match /creator_nutrition_library/{creatorId}/meals/{mealId} {
      allow read, write: if isSignedIn() && request.auth.uid == creatorId;
    }
    match /creator_nutrition_library/{creatorId}/plans/{planId} {
      allow read, write: if isSignedIn() && request.auth.uid == creatorId;
    }

    match /nutrition_assignments/{assignmentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.assignedBy == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && isCreator() && request.resource.data.assignedBy == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.assignedBy == request.auth.uid || isAdmin()
      );
    }

    // Client nutrition plan content: per-assignment copy (doc id = assignmentId).
    // Client can read their copy; creator (assignedBy) can read/write.
    // Requires userId + assignedBy fields on the document itself (avoids get() on nutrition_assignments).
    match /client_nutrition_plan_content/{assignmentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.assignedBy == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        (isCreator() && request.resource.data.assignedBy == request.auth.uid
          && request.resource.data.keys().hasAll(['userId', 'assignedBy']))
        || isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        resource.data.assignedBy == request.auth.uid ||
        isAdmin()
      );
    }

    // ============================================
    // EVENTS
    // ============================================

    match /events/{eventId} {
      allow read: if true;
      allow create: if isCreator() && request.resource.data.creator_id == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid || isAdmin()
      );
      // registration_count is managed by Cloud Functions (sendEventConfirmationEmail) — no client update
      allow delete: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid || isAdmin()
      );
    }

    match /event_signups/{eventId}/registrations/{regId} {
      // wake_users_only events require auth; open events allow anyone
      allow create: if (
        get(/databases/$(database)/documents/events/$(eventId)).data.get('wake_users_only', false) == false
        || isSignedIn()
      );
      // Creator and admin can read all registrations; registrant can read their own (by doc id matching uid)
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(eventId)).data.creator_id == request.auth.uid
        || isAdmin()
        || regId == request.auth.uid
        || resource.data.get('userId', '') == request.auth.uid
      );
      allow update: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(eventId)).data.creator_id == request.auth.uid
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /event_signups/{eventId}/waitlist/{waitId} {
      // Security (audit H-02): require auth + bind userId to caller. Previously
      // `allow create: if true` allowed unauthenticated public writes with no
      // schema constraints — anyone could spam arbitrary docs into any event's
      // waitlist subcollection.
      allow create: if isSignedIn() && (
        request.resource.data.get('userId', '') == request.auth.uid
        || waitId == request.auth.uid
      );
      // Creator and admin can read all waitlist entries; waitlist user can read their own
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(eventId)).data.creator_id == request.auth.uid
        || isAdmin()
        || waitId == request.auth.uid
        || resource.data.get('userId', '') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ============================================
    // CREATOR FEEDBACK (suggestions / bug reports)
    // ============================================
    match /creator_feedback/{feedbackId} {
      allow create: if isSignedIn() && isCreator() && request.resource.data.creatorId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // PLANS (one-on-one delivery)
    // ============================================
    match /plans/{planId} {
      // Creator owner and admin can read/write; enrolled client can read their assigned plan
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isAdmin() ||
        resource.data.get('clientUserId', '') == request.auth.uid
      );
      allow create: if isCreator() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
      match /modules/{moduleId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/plans/$(planId)).data.creatorId == request.auth.uid
          || get(/databases/$(database)/documents/plans/$(planId)).data.get('clientUserId', '') == request.auth.uid
          || isAdmin()
        );
        allow write: if isSignedIn() && (
          get(/databases/$(database)/documents/plans/$(planId)).data.creatorId == request.auth.uid
          || isAdmin()
        );
        match /sessions/{sessionId} {
          allow read: if isSignedIn() && (
            get(/databases/$(database)/documents/plans/$(planId)).data.creatorId == request.auth.uid
            || get(/databases/$(database)/documents/plans/$(planId)).data.get('clientUserId', '') == request.auth.uid
            || isAdmin()
          );
          allow write: if isSignedIn() && (
            get(/databases/$(database)/documents/plans/$(planId)).data.creatorId == request.auth.uid
            || isAdmin()
          );
        }
      }
    }

    // ============================================
    // CREATOR LIBRARIES
    // ============================================
    match /creator_libraries/{creatorId} {
      allow read, write: if isOwner(creatorId) || isAdmin();
      match /sessions/{sessionId} {
        allow read, write: if isOwner(creatorId) || isAdmin();
      }
      match /modules/{moduleId} {
        allow read, write: if isOwner(creatorId) || isAdmin();
      }
    }

    // ============================================
    // EXERCISES LIBRARY (shared)
    // ============================================
    // Security (audit H-04): writes scoped to the document's creator_id field.
    // Previously `allow create, update: if isCreator()` let any creator
    // overwrite any other creator's exercise library.
    match /exercises_library/{exerciseId} {
      allow read: if isSignedIn();
      allow create: if isCreator()
        && request.resource.data.get('creator_id', '') == request.auth.uid;
      allow update: if isAdmin() || (isCreator()
        && resource.data.get('creator_id', '') == request.auth.uid
        && request.resource.data.get('creator_id', '') == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================
    // CLIENT PROGRAMS & SESSION CONTENT
    // ============================================

    // Client programs (doc id = userId_programId)
    match /client_programs/{docId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCreator() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
    }

    // One-on-one sessions assigned to a client
    match /client_sessions/{sessionId} {
      allow read: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid ||
        resource.data.client_id == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCreator() && request.resource.data.creator_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid || isAdmin()
      );
    }

    match /client_session_content/{docId} {
      allow read: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid ||
        resource.data.client_id == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCreator() && request.resource.data.creator_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.creator_id == request.auth.uid || isAdmin()
      );
    }

    match /client_plan_content/{docId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCreator() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
    }

    // ============================================
    // PROGRESS (top-level, user_id field scoped)
    // ============================================
    match /progress/{docId} {
      allow read: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isAdmin()
      );
    }

    // ============================================
    // COMMUNITY
    // ============================================
    match /community/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isAdmin()
      );
    }

    // ============================================
    // SERVER-ONLY COLLECTIONS (never client-accessible)
    // ============================================

    // API keys — SHA-256 hashes, must never be readable from clients
    match /api_keys/{keyId} {
      allow read, write: if false;
    }

    // MercadoPago webhook idempotency records
    match /processed_payments/{paymentId} {
      allow read, write: if false;
    }

    // FatSecret API cache — server-managed
    match /fatsecret_cache/{cacheId} {
      allow read, write: if false;
    }

    // ============================================
    // SUBSCRIPTION CANCELLATION FEEDBACK
    // ============================================
    match /subscription_cancellation_feedback/{feedbackId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // PROGRAM LEAVE FEEDBACK
    // ============================================
    // Server-only reads. Creator sees aggregated counts via API only — never raw rows.
    match /program_leave_feedback/{feedbackId} {
      allow create: if false; // All writes via Cloud Function (Admin SDK bypasses)
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // WRITE ACCESS REQUESTS (developer portal)
    // ============================================
    match /write_access_requests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // BUNDLES (multi-program SKUs)
    // ============================================
    match /bundles/{bundleId} {
      allow read: if resource.data.status == 'published'
                  || (isSignedIn() && request.auth.uid == resource.data.creatorId)
                  || isAdmin();
      allow create: if isSignedIn()
                    && isCreator()
                    && request.auth.uid == request.resource.data.creatorId
                    && request.resource.data.status == 'draft';
      allow update: if isSignedIn() && request.auth.uid == resource.data.creatorId;
      allow delete: if false;
    }

    // ============================================
    // ORPHANED LEGACY COLLECTIONS (zero code references, safe to delete from console)
    // - checkout_intents (4 docs)
    // - creator_client_access (7 docs) — replaced by one_on_one_clients
    // ============================================

    // ============================================
    // DEFAULT RULE — deny everything not explicitly covered
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
