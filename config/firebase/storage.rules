rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures (Tier 5.2 lockdown)
    // Read: owner or admin only. The previous role-based read branch
    // (allow if target user has role creator/admin) let an attacker enumerate
    // the creator/admin roster by probing UIDs — read-success vs permission-
    // denied was a side-channel. Legitimate display of creator photos in
    // client surfaces uses Firebase Storage download tokens (getDownloadURL),
    // which bypass rules, so this tightening doesn't break tokened access.
    // Write enforcement is at the API layer via signed URLs.
    match /profiles/{userId}/{fileName} {
      allow read: if request.auth != null
        && (
          request.auth.uid == userId
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 200 * 1024  // Max 200KB (compress before upload)
        && request.resource.contentType.matches('image/.*');  // Only images
    }

    // Profile pictures — current path used by signed-URL uploads
    // (profiles/{userId}/ above is legacy data). Same lockdown applies.
    match /profile_pictures/{userId}/{fileName} {
      allow read: if request.auth != null
        && (
          request.auth.uid == userId
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 200 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Exercise library videos — F-RULES-25: writes restricted to library
    // owner (creator who owns exercises_library/{libraryId}.creator_id).
    // Previously any authenticated user could write up to 500 MB into any
    // creator's library, enabling cross-creator content insertion + storage
    // billing abuse.
    match /exercises_library/{libraryId}/{exerciseName}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.contentType.matches('video/.*')
        && request.resource.size < 500 * 1024 * 1024  // Max 500MB
        && firestore.exists(/databases/(default)/documents/exercises_library/$(libraryId))
        && firestore.get(/databases/(default)/documents/exercises_library/$(libraryId)).data.get('creator_id', '') == request.auth.uid;
    }

    // Program images — F-RULES-26: writes bound to courses/{programId}.creator_id.
    // Defacement of any creator's program assets was possible before.
    match /courses/{programId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/courses/$(programId))
        && firestore.get(/databases/(default)/documents/courses/$(programId)).data.get('creator_id', '') == request.auth.uid
        && (
          (fileName.matches('image\\..*')
            && request.resource.size < 10 * 1024 * 1024
            && request.resource.contentType.matches('image/.*'))
          ||
          (fileName.matches('intro_video\\..*')
            && request.resource.contentType.matches('video/.*'))
        );
    }

    // Program tutorial videos — F-RULES-27 (4-segment path per audit §13.3).
    match /courses/{programId}/tutorials/{screenName}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.contentType.matches('video/.*')
        && firestore.exists(/databases/(default)/documents/courses/$(programId))
        && firestore.get(/databases/(default)/documents/courses/$(programId)).data.get('creator_id', '') == request.auth.uid;
    }

    // Session images — F-RULES-27.
    match /courses/{programId}/modules/{moduleId}/sessions/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.exists(/databases/(default)/documents/courses/$(programId))
        && firestore.get(/databases/(default)/documents/courses/$(programId)).data.get('creator_id', '') == request.auth.uid;
    }
    
    // Creator cards (images and videos)
    match /cards/{userId}/{fileName} {
      // Allow authenticated users to read cards
      allow read: if request.auth != null;

      // Allow users to write only their own cards
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)  // Max 10MB for images
          ||
          (request.resource.contentType.matches('video/.*') && request.resource.size < 500 * 1024 * 1024)  // Max 500MB for videos
        );
    }
    
    // Creator media library (personal folder: images/videos for reuse across programs/sessions)
    // Read requires auth — embedded <img> tags use download tokens which bypass
    // rules, so authed access doesn't break legitimate program/session display.
    // Untokened path probing (the enumeration vector) is now blocked.
    match /creator_media/{creatorId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == creatorId
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
          ||
          (request.resource.contentType.matches('video/.*') && request.resource.size < 500 * 1024 * 1024)
        );
    }

    // Creator feedback attachments (screenshots for bug reports / suggestions)
    match /creator_feedback_attachments/{creatorId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == creatorId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Legal documents (publicly readable, admin-only write via Admin SDK)
    match /legal-documents/{fileName} {
      allow read: if true;
      allow write: if false;  // Admin SDK bypasses rules
    }

    // Legacy legal documents path (publicly readable, admin-only write via Admin SDK)
    match /legal/{fileName} {
      allow read: if true;
      allow write: if false;  // Admin SDK bypasses rules
    }
    
    // Progress photos — private to the owner
    // Upload enforcement at API layer — see signed URL flow in CLAUDE.md
    match /progress_photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 500 * 1024  // Max 500KB (compress before upload)
        && request.resource.contentType.matches('image/.*');
    }

    // Body progress photos — private to the owner
    // Upload enforcement at API layer — see signed URL flow in CLAUDE.md
    match /body_log/{userId}/{date}/{photoId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 500 * 1024  // Max 500KB (compress before upload)
        && request.resource.contentType.matches('image/.*');
    }

    // Event cover images — F-RULES-28: writes bound to event creator.
    // Public read remains for landing/marketing surfaces. Previously any
    // authed user could overwrite any event's cover image (defacement).
    match /events/{eventId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.exists(/databases/(default)/documents/events/$(eventId))
        && firestore.get(/databases/(default)/documents/events/$(eventId)).data.get('creator_id', '') == request.auth.uid;
    }

    // Public landing assets (hero clips, marketing media) — readable by anyone.
    // Upload via Admin SDK or Firebase Console only; Admin SDK bypasses rules.
    match /app_resources/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Video exchange submissions (client ↔ creator videos + thumbnails).
    // Read: only the two participants of the exchange (creator or client).
    // Write: blocked — all writes go through signed URLs issued by the API.
    match /video_exchanges/{exchangeId}/{messageId}/{fileName} {
      allow read: if request.auth != null
        && (
          firestore.get(/databases/(default)/documents/video_exchanges/$(exchangeId)).data.creatorId == request.auth.uid
          ||
          firestore.get(/databases/(default)/documents/video_exchanges/$(exchangeId)).data.clientId == request.auth.uid
        );
      allow write: if false;
    }

    // Deny all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

