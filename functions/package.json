{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "npx tsc && cp -r src/assets lib/assets 2>/dev/null || true && cp ../hosting/index.html lib/landing-index.html 2>/dev/null || true",
    "build:watch": "npx tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "vitest run tests/rules",
    "test:rules:security": "vitest run tests/rules/security",
    "test:api": "WAKE_RUN_API_TESTS=1 vitest run tests/api",
    "test:chains": "WAKE_RUN_API_TESTS=1 vitest run tests/security",
    "test:security": "vitest run tests/rules tests/api tests/security",
    "test:security:full": "WAKE_RUN_API_TESTS=1 vitest run tests/rules tests/api tests/security",
    "emu:start": "firebase emulators:start --only functions,firestore,auth,storage --project wolf-20b8b"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/monitoring": "^5.3.1",
    "@types/sanitize-html": "^2.16.1",
    "express": "^5.2.1",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^4.8.1",
    "mercadopago": "^2.10.0",
    "resend": "^6.9.3",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "source-map": "^0.7.6",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/express": "^5.0.6",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "fast-check": "^3.23.2",
    "firebase-functions-test": "^3.1.0",
    "openapi-types": "^12.1.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  },
  "private": true
}
