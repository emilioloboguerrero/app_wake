{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "postdeploy": [
        "bash scripts/ops/notify-deploy.sh functions"
      ]
    }
  ],

  "hosting": {
    "public": "hosting",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.map"
    ],
    "postdeploy": [
      "bash scripts/ops/upload-sourcemaps.sh",
      "bash scripts/ops/notify-deploy.sh hosting"
    ],
    "rewrites": [
      { "source": "/api/**", "function": "api", "region": "us-central1" },
      { "source": "/e/**", "function": "eventPage", "region": "us-central1" },
      { "source": "/app", "destination": "/app/index.html" },
      { "source": "/app/**", "destination": "/app/index.html" },
      { "source": "/creators", "destination": "/creators/index.html" },
      { "source": "/creators/**", "destination": "/creators/index.html" },
      { "source": "/developers", "destination": "/developers/index.html" },
      { "source": "/developers/**", "destination": "/developers/index.html" },
      { "source": "/landing", "destination": "/index.html" },
      { "source": "/landing/**", "destination": "/index.html" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/app/sw.js",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/javascript; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|jpg|jpeg|gif|png|svg|webp|woff|woff2|ttf|eot)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "config/firebase/firestore.rules",
    "indexes": "config/firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "config/firebase/storage.rules"
  },
  "emulators": {
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "auth": { "port": 9099 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true, "port": 4000 }
  }
}
